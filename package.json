{
  "name": "cpd-wage-predictor",
  "version": "0.1.0",
  "description": "Offline fiscal-year wage and work-study forecasting for Chapman CPD",
  "main": "out/main/index.js",
  "author": "Chapman University CPD",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.7",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@swc/core": "1.13.5",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.5.3",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "postcss": "8.5.19",
    "tailwindcss": "3.4.19",
    "typescript": "7.0.2",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "build": {
    "appId": "edu.chapman.cpd.wagepredictor",
    "productName": "CPD Wage Predictor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "category": "Office",
      "target": [
        "AppImage"
      ]
    }
  }
}
